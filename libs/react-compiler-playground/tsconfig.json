{
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "types": ["react/experimental", "node"],
    "lib": ["dom", "dom.iterable", "esnext"]
  },
  "include": ["src"]
}
